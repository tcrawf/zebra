{
    "intelephense.environment.phpVersion": "8.4",
    // PHP executable path (required for phpcbf)
    "php.validate.executablePath": "/usr/bin/php",
    "php.executablePath": "/usr/bin/php",
    // PHP CodeSniffer extension (IoannisKappas.phpcs) - Primary for linting
    // Install: Extensions → Search "PHP CodeSniffer" by Ioannis Kappas
    // NOTE: Temporarily disabled - phpsab extension handles both linting and fixing
    // If you want to use this extension, uncomment below and disable phpsab.snifferEnable
    // "phpcs.enable": true,
    // "phpcs.executablePath": "vendor/bin/phpcs",
    // "phpcs.standard": "phpcs.xml",
    // "phpcs.autoConfigSearch": false,
    // "phpcs.showSources": true,
    // "phpcs.showWarnings": true,
    // "phpcs.showErrors": true,
    // "phpcs.validateExecutable": false,
    // "phpcs.lintOnSave": true,
    // "phpcs.lintOnType": false,
    // PHP Sniffer & Beautifier extension (valeryanm.vscode-phpsab) - For formatting
    // Install: Extensions → Search "PHP Sniffer & Beautifier" by Valeryanm
    "phpsab.standard": "phpcs.xml",
    "phpsab.autoConfigSearch": false,
    "phpsab.executablePathCS": "vendor/bin/phpcs",
    "phpsab.executablePathCBF": "vendor/bin/phpcbf",
    "phpsab.executablePathPHP": "/usr/bin/php",
    "phpsab.snifferShowSources": true,
    "phpsab.snifferShowWarnings": true,
    "phpsab.snifferShowErrors": true,
    "phpsab.validateExecutable": false,
    "phpsab.enable": true,
    "phpsab.snifferEnable": true,
    "phpsab.fixerEnable": true,
    "phpsab.snifferMode": "onSave",
    // Format on save for PHP files using phpcbf
    "[php]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "valeryanm.vscode-phpsab",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        }
    },
    // File settings
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "phpsab.debug": true
}
